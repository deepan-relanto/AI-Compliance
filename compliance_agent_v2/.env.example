# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# NVIDIA Integrate API — MCQ generation
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Microsoft Entra ID (Azure AD) — required for login
AUTH_AZURE_AD_CLIENT_ID=
AUTH_AZURE_AD_TENANT_ID=
AUTH_AZURE_AD_CLIENT_SECRET=

# NextAuth / Auth.js (generate: openssl rand -base64 32)
AUTH_SECRET=
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Azure Portal → App registrations → your app → Authentication → Redirect URIs (Web):
#   http://localhost:3000/api/auth/callback/microsoft-entra-id
# Production: https://YOUR-HOST/api/auth/callback/microsoft-entra-id
# Must match exactly (no trailing slash).
# See RENDER_DEPLOY.md for Render.com setup.

# Microsoft Graph — batch invitation & completion emails (Application Mail.Send)
# Uses AUTH_AZURE_* above unless GRAPH_* overrides are set.
MAIL_FROM_ADDRESS=training@relanto.ai
# Optional overrides (defaults to AUTH_AZURE_AD_*):
# GRAPH_TENANT_ID=
# GRAPH_CLIENT_ID=
# GRAPH_CLIENT_SECRET=
