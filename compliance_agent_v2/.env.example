# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# NVIDIA Integrate API — MCQ generation
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Microsoft Entra ID (Azure AD) — required for login
AUTH_AZURE_AD_CLIENT_ID=
AUTH_AZURE_AD_TENANT_ID=
AUTH_AZURE_AD_CLIENT_SECRET=

# NextAuth / Auth.js (generate: openssl rand -base64 32)
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Azure Portal → App registrations → your app → Authentication → Redirect URIs (Web):
#   http://localhost:3000/api/auth/callback/microsoft-entra-id
# Production: https://YOUR-HOST/api/auth/callback/microsoft-entra-id
# Must match exactly (no trailing slash).
# See RENDER_DEPLOY.md for Render.com setup.

# Microsoft Graph — batch invitation & completion emails (Application Mail.Send)
# Uses AUTH_AZURE_* above unless GRAPH_* overrides are set.
MAIL_FROM_ADDRESS=training@relanto.ai
# Optional overrides (defaults to AUTH_AZURE_AD_*):
# GRAPH_TENANT_ID=
# GRAPH_CLIENT_ID=
# GRAPH_CLIENT_SECRET=

# TalkingHead avatar (served from public/avatars)
NEXT_PUBLIC_TALKINGHEAD_MODEL_URL=/avatars/julia.glb
NEXT_PUBLIC_TALKINGHEAD_CDN_URL=https://esm.sh/@met4citizen/talkinghead?bundle

# HeadTTS (optional browser TTS pipeline)
NEXT_PUBLIC_HEADTTS_CDN_URL=https://cdn.jsdelivr.net/npm/@met4citizen/headtts@1.3/+esm
NEXT_PUBLIC_HEADTTS_WORKER_URL=https://cdn.jsdelivr.net/npm/@met4citizen/headtts@1.3/modules/worker-tts.mjs
NEXT_PUBLIC_HEADTTS_DICTIONARY_URL=https://cdn.jsdelivr.net/npm/@met4citizen/headtts@1.3/dictionaries/
# Feminine pleasant Kokoro voice. af_bella + 1.2 speed = less robotic drag.
# (af_nicole is whispery/slow; af_heart is warm but flatter.)
NEXT_PUBLIC_HEADTTS_VOICE=af_bella
NEXT_PUBLIC_HEADTTS_SPEED=1.2

# Gemini — TTS script generation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
