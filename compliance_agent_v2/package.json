{
  "name": "compliance-agent-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/ensure-next-in-project.mjs && next dev",
    "dev:turbo": "node scripts/ensure-next-in-project.mjs && next dev --turbo",
    "build": "node scripts/ensure-next-in-project.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:migrate:alter": "node scripts/db-migrate-alter.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "db:seed:relanto": "node scripts/db-seed-relanto-users.mjs",
    "db:seed:employees": "node scripts/db-seed-employees.mjs",
    "db:reset-course-assignments": "node scripts/db-reset-course-assignments.mjs",
    "db:sync-course-assets": "node scripts/db-sync-course-assets.mjs",
    "db:verify-course-assets": "node scripts/db-verify-course-assets.mjs",
    "db:clear-modules": "node scripts/db-clear-modules.mjs",
    "db:clear-progress": "node scripts/db-clear-progress.mjs",
    "db:fix-failed-scores": "node scripts/db-fix-failed-scores.mjs",
    "db:reconcile-progress": "npx --yes tsx scripts/db-reconcile-progress.ts",
    "benchmark:latency": "npx --yes tsx scripts/latency-benchmark.ts",
    "db:clear-feedback": "node scripts/db-clear-feedback.mjs",
    "db:clear-monitoring": "node scripts/db-clear-monitoring.mjs",
    "db:clear-all": "node scripts/db-clear-all.mjs",
    "db:reset": "node scripts/db-reset.mjs",
    "db:setup": "npm run db:migrate && npm run db:migrate:alter && npm run db:seed"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "next-auth": "^5.0.0-beta.25",
    "papaparse": "^5.5.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-pdf": "^9.2.1",
    "tailwind-merge": "^3.3.0",
    "ws": "^8.21.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.29",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "postgres": "^3.4.5",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  }
}
