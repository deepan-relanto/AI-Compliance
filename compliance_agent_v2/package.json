    "db:reshuffle:mcqs": "node scripts/db-reshuffle-mcq-options.mjs",
    "db:reconcile-progress": "node scripts/db-reconcile-progress.mjs",
    "db:reset-course-assignments": "node scripts/db-reset-course-assignments.mjs",
    "db:update-bundle-html": "node scripts/db-update-bundle-html.mjs",
