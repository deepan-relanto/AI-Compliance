    "next": "^15.3.3",
    "next-auth": "^5.0.0-beta.25",
    "papaparse": "^5.5.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-pdf": "^9.2.1",
    "sharp": "^0.35.2",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.3.0",
    "zustand": "^5.0.5",
    "ws": "^8.21.0"
