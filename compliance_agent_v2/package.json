    "db:migrate:alter": "node scripts/db-migrate-alter.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "db:seed:relanto": "node scripts/db-seed-relanto-users.mjs",
    "db:seed:employees": "node scripts/db-seed-employees.mjs",
    "db:import:employees": "node scripts/db-import-employees-xlsx.mjs",
    "db:prune:employees": "node scripts/db-prune-employees.mjs",
    "db:clear-modules": "node scripts/db-clear-modules.mjs",
    "db:clear-progress": "node scripts/db-clear-progress.mjs",
    "db:fix-failed-scores": "node scripts/db-fix-failed-scores.mjs",
    "db:clear-feedback": "node scripts/db-clear-feedback.mjs",
    "db:clear-monitoring": "node scripts/db-clear-monitoring.mjs",
    "db:clear-batches-monitoring": "node scripts/db-clear-batches-monitoring.mjs",
    "db:clear-assignments-monitoring": "node scripts/db-clear-assignments-monitoring.mjs",
